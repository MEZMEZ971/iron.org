# Vite dev proxy target — used by vite.config.ts when VITE_API_URL is unset in dev
VITE_API_PROXY_TARGET=http://localhost:3000

# Leave VITE_API_URL unset in dev: client.ts falls back to http://localhost:3000.
# To hit the live Railway backend from local dev, uncomment:
# VITE_API_URL=https://ironorg-production.up.railway.app
