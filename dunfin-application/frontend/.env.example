# Vite dev proxy target — used by vite.config.ts when VITE_API_URL is unset in dev
VITE_API_PROXY_TARGET=http://localhost:3000

# Production API (set in Vercel / .env.production for builds)
# VITE_API_URL=https://your-api.example.com

# Public frontend origin (custom domain)
# VITE_FRONTEND_URL=https://your-custom-domain.com
