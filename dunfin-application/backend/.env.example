# PostgreSQL (required for Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/dunfin?schema=public"

# Blockchain forwarder — Ethereum mainnet via Infura
DEPLOYER_PRIVATE_KEY=
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID

# Active CREATE2 factory (set to NewFactoryAddress after deployMainNet.cjs)
FACTORY_ADDRESS=

# Previous staging/test factory — optional; keeps old forwarder monitoring alive
LEGACY_FACTORY_ADDRESS=

# Production treasury wallet (must match factory centralWallet at deploy time)
MAIN_PARTNER_WALLET_ADDRESS=

# Ethereum mainnet USDT (6 decimals)
USDT_ADDRESS=0xdAC17F958D2ee523a2206206994597C13D831ec7
# Ethereum mainnet USDC (6 decimals)
USDC_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48

# Binance Smart Chain (BEP20) stablecoins (6/18 decimals per token)
USDT_ADDRESS_BEP20=0x55d398326f99059fF775485246999027B3197955
USDC_ADDRESS_BEP20=0x8AC76a51cc950d9822D68b83FE1Ad97B32CD580d

# Optional: choose which EVM chain the backend connects to (ETH | BSC)
# EVM_CHAIN=ETH

# BSC mainnet JSON-RPC (required when EVM_CHAIN=BSC)
BSC_RPC_URL=

# TRON deposit watcher (TronGrid)
TRON_API_URL=https://api.trongrid.io
TRONGRID_API_KEY=99701d12-6304-4aa1-9da8-37a368fc25fa
# Backwards compatible (older env name)
TRON_API_KEY=99701d12-6304-4aa1-9da8-37a368fc25fa
TRON_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
TRON_USDC_CONTRACT=TEkxiTehnzSmSe2XqrBj4w32RUN966rdz8
DEPOSIT_WATCHER_MS=30000
DEPOSIT_WATCHER_LOOKBACK_MS=86400000

PORT=3000

# Public frontend origin (custom domain). Required in production for invite links and CORS.
FRONTEND_URL=http://localhost:5173

# Optional extra CORS origins (comma-separated), e.g. Vercel preview URLs
# ALLOWED_ORIGINS=https://preview.example.vercel.app

# Legacy single-origin override; merged with FRONTEND_URL and ALLOWED_ORIGINS
CORS_ORIGIN=http://localhost:5173
